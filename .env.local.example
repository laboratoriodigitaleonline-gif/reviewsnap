ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for Amazon scraping — free tier at https://scraperapi.com (1,000 req/month)
SCRAPERAPI_KEY=your_scraperapi_key_here

# Upstash Redis — when set, product analyses are stored in Redis instead of the local JSON file.
# Connect Upstash to your Vercel project; these vars are auto-populated by the integration.
# Leave blank to use local file storage (data/products.json) during development.
KV_REST_API_URL=
KV_REST_API_TOKEN=
